# Porta local. No Render, ele injeta PORT automaticamente.
PORT=3000

# Troque em produção.
SESSION_SECRET=troque-esta-chave

# Admin inicial criado na primeira execução.
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# GitHub OAuth App
# Crie em: GitHub > Settings > Developer settings > OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Exemplo local:
# http://localhost:3000/auth/github/callback
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback
